---
const { word, pronunciation, type, meanings, examplesES, examplesNA  } = Astro.props;


---


  <!-- Palabra -->
  <h1 class="text-3xl font-bold text-center text-gray-800">
    {word}
  </h1>

  <!-- Pronunciación -->
  {pronunciation && (
    <p class="text-center text-gray-500 mt-1">
      ({pronunciation})
    </p>
  )}

  <!-- Tipo -->
  <p class="text-center italic text-gray-600 mt-2">
    {type}
  </p>

  <!-- Significados -->
  <div class="mt-6">
    <h3 class="text-lg font-semibold text-yellow-700 mb-2">
      Significado
    </h3>

    <ul class="list-disc list-inside space-y-1 text-gray-700">

        <li>{meanings}</li>

    </ul>
  </div>

  <!-- Ejemplos -->
  <div class="mt-6">
    <h3 class="text-lg font-semibold text-yellow-700 mb-2">
      Ejemplos
    </h3>

    <ol class="space-y-3 text-gray-700">
        <li class="bg-white rounded-lg p-3 shadow-sm">
          <p><span class="font-semibold">NA:</span> {examplesNA}</p>
          <p><span class="font-semibold">ES:</span> {examplesES}</p>
        </li>
    </ol>
  </div>
