---
import ModalResultado from './ModalResultado.astro';

interface Props {
  categorias: Record<string, string[]>;
  lengua: string;
}

const { categorias, lengua } = Astro.props as Props;
const letras = Object.keys(categorias);


---

<section>
  <h2>Palabras en { lengua }</h2>

  <!-- MENÚ -->
  <ul class="flex flex-wrap gap-3 py-5">
    {letras.map((letra) => (
      <li class="letra cursor-pointer" data-letra={letra}>
        {letra.toUpperCase()}
      </li>
    ))}

    <li class="letra cursor-pointer active w-auto px-3" data-letra="all">
      Ver todo
    </li>
  </ul>

  <!-- CONTENIDO -->
  
  {Object.entries(categorias).map(([letra, palabras]) => (
    <div data-group={letra} class="grupo mb-10">
      <p class="text-xl text-center text-primary-700 font-display font-bold bg-orange-400/20 border-b border-dotted py-1 mb-2">
        Palabras con <strong class="uppercase font-bold">{letra}</strong>
      </p>

      <p class="flex flex-wrap gap-3">
        {palabras.map((palabra) => (
          <a class="palabra" >{palabra}</a>
        ))}
      </p>
    </div>
  ))}
</section>

<div class="fixed inset-0 place-content-center bg-black/50 hidden modal-prueba">
<div class="max-w-md mx-auto bg-[#f9f7f1] rounded-2xl shadow-md p-6">
  <button id="quitar">X</button>
    <ModalResultado
      word = 'Alt'
      pronunciation = 'at'
      type = 'sustantivo'
      meanings = 'Agua'
      examplesES = 'Nimitzmacaz atl.'
      examplesNA = 'Te daré agua.'
    />  
  </div>
</div>

<script>
  //Eventos para abrir modal y cerrar 
  const btnPalabra = document.querySelectorAll('a.palabra');
  const modal = document.querySelector('.modal-prueba')
  const btnQuitar = document.querySelector('#quitar')
  
  // Maneja los clics en cada botón.
  btnPalabra.forEach((button) => {
    button.addEventListener('click', () => {
      modal?.classList.remove('hidden')
    });
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.add('hidden');
    }
  });

  btnQuitar.addEventListener('click', () => {
    modal.classList.add('hidden');
  });



  const botones = document.querySelectorAll(".letra");
  const grupos = document.querySelectorAll(".grupo");

  function activar(letra) {
    // Quitar active
    botones.forEach(b => b.classList.remove("active"));

    // Agregar active al clickeado
    document.querySelector(`[data-letra="${letra}"]`)
      ?.classList.add("active");

    // Mostrar / ocultar grupos
    grupos.forEach(g => {
      if (letra === "all") {
        g.style.display = "block";
      } else {
        g.style.display =
          g.dataset.group === letra ? "block" : "none";
      }
    });
  }

  botones.forEach(boton => {
    boton.addEventListener("click", () => {
      activar(boton.dataset.letra);
    });
  });

  // Estado inicial
  activar("all");
</script>
